{
  "name": "@sentinel-vrt/db",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/essandhu/Sentinel.git",
    "directory": "packages/db"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@sentinel-vrt/types": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.0",
    "postgres": "^3.0.0"
  },
  "devDependencies": {
    "@sentinel-vrt/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "dotenv": "^16.0.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
