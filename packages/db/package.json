    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@sentinel/types": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.0",
    "postgres": "^3.0.0"
  },
  "devDependencies": {
    "@sentinel/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "dotenv": "^16.0.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
