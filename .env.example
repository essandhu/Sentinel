# =============================================================================
# Sentinel - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For local development with Docker Compose defaults, most values below work as-is.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel

# -----------------------------------------------------------------------------
# Redis (BullMQ job queue, caching, pub/sub)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# S3-Compatible Object Storage (MinIO for local dev)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sentinel
S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Maximum API requests per minute per client (default: 100)
# API_RATE_LIMIT_MAX=100

# Public URL of the dashboard (used in notification links)
# DASHBOARD_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Authentication (Clerk) - Optional
# -----------------------------------------------------------------------------
# Clerk is optional. The app runs without auth if these are not set.
# CLERK_SECRET_KEY=sk_test_...
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# Encryption - Optional
# -----------------------------------------------------------------------------
# 32-byte hex key for encrypting sensitive data (e.g., integration tokens).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=
